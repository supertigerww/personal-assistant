BOT_TOKEN=your-telegram-bot-token
XAI_API_KEY=your-xai-api-key
XAI_MODEL=grok-4.1
XAI_BASE_URL=https://api.x.ai/v1
XAI_IMAGE_MODEL=grok-imagine-image-quality
XAI_MAX_RETRIES=2
XAI_RETRY_DELAY_SECONDS=1.0
SQLITE_PATH=data/queen_bot.sqlite3
PROMPT_PATH=prompts/system_prompt.txt
LOG_LEVEL=INFO
ENABLE_IMAGE_GENERATION=false
ENABLE_CHROMA=false
TASK_NORMAL_MIN_TURNS=8
TASK_NORMAL_MAX_TURNS=15
TASK_INTENSE_MIN_TURNS=5
TASK_INTENSE_MAX_TURNS=10
AFTERCARE_DURATION_MINUTES=30
ASSETS_IMAGES_PATH=/app/assets/images
ASSETS_VIDEOS_PATH=/app/assets/videos
HOST_DATA_PATH=./data
HOST_ASSETS_IMAGES_PATH=./assets/images
HOST_ASSETS_VIDEOS_PATH=./assets/videos
SAFEWORDS_CSV=red,红色,stop,pause,停,结束,暂停,停止,停下
